export default "//组件内部默认内置3种模式design|readonly|preview，通过传入重置某种模式的权限\r\n//也可以自定于扩展自己的模式 {design: {....}, myMode: {showToolbar: true,.....}}\r\n{\r\n  \"design\": {  //模式名称\r\n    {\r\n      // UI 显示\r\n      /** 是否允许显示顶部工具栏 */\r\n      showToolbar: true\r\n      /** 是否允许显示左侧节点栏 */\r\n      showNodePalette: true,\r\n      /** 是否允许显示右侧属性栏 */\r\n      showPropertiesPanel: true,\r\n      /** 是否允许显示右键菜单 */\r\n      showContextMenu: true,\r\n      /** 是否允许显示节点 tooltip */\r\n      canNodeTooltip: true,\r\n      /** 是否允许显示连线 tooltip */\r\n      canEdgeTooltip: true,\r\n      /** 是否显示小地图（minimap） */\r\n      showMinimap: true,\r\n\r\n      // 编辑能力\r\n      /** 是否允许拖拽节点 */\r\n      canDrag: true,\r\n      /** 是否允许创建连线 */\r\n      canConnect: true,\r\n      /** 是否允许删除元素节点&连线 */\r\n      canDelete: true,\r\n      /** 是否允许复制节点 */\r\n      canCopy: true,\r\n      /** 是否允许粘贴节点 */\r\n      canPaste: true,\r\n      /** 是否允许节点成组功能 */\r\n      canGroup: true,\r\n      /** 节点/连线层级前置 */\r\n      canToFront: true,\r\n      /** 节点/连线层级后置 */\r\n      canToBack: true,\r\n\r\n      // 选择能力\r\n      /** 控制多选（multiple）和框选（rubberband） */\r\n      canMultipleSelect: true,\r\n      /** 与 canMultipleSelect 共同控制全选（Ctrl+A / 右键全选） */\r\n      canSelectAll: true,\r\n\r\n      // 对齐能力\r\n      canAlign: true,       // 总开关\r\n      canAlignLeft: true,   // 左对齐\r\n      canAlignRight: true,  // 右对齐\r\n      canAlignTop: true,    // 上对齐\r\n      canAlignBottom: true, // 下对齐\r\n\r\n      // 操作能力\r\n      canImport: true,     // 导入\r\n      canExport: true,     // 导出\r\n      canUndo: true,       // 撤销\r\n      canRedo: true,       // 重做\r\n\r\n      // 视图能力\r\n      canZoom: true,       // 放大缩小\r\n      canPan: true,        // 拖动画布\r\n      canFitView: true,    // 适应画布\r\n      canResetView: true,  // 重置视图\r\n\r\n      // 交互反馈能力\r\n      /** 是否允许节点 hover 样式变化（高亮、tooltip、流动动画等） */\r\n      canHoverNode: true,\r\n      /** 是否允许连线 hover 样式变化（高亮、tooltip 等） */\r\n      canHoverEdge: true,\r\n      /** 是否允许选中节点 */\r\n      canSelectNode: true,\r\n      /** 是否允许选中连线 */\r\n      canSelectEdge: true\r\n    }\r\n  },\r\n  readonly: {},\r\n  preview: {}\r\n}\r\n"